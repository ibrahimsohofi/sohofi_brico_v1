# Sales Manager Environment Configuration
# ========================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bricojamal

# Products Manager Integration
# ============================
# URL to the products_manager API (for inventory sync)
VITE_PRODUCTS_MANAGER_URL=http://localhost:5000
VITE_PRODUCTS_MANAGER_WS_URL=ws://localhost:5000

# Sales Manager API (self-reference for frontend)
VITE_SALES_MANAGER_URL=http://localhost:3001

# Integration Settings
# ====================
# Health check interval in milliseconds (default: 30000 = 30 seconds)
VITE_HEALTH_CHECK_INTERVAL=30000

# Real-time sync polling interval in milliseconds (default: 5000 = 5 seconds)
VITE_SYNC_POLL_INTERVAL=5000

# Maximum retry attempts for failed API calls
VITE_MAX_RETRIES=3

# Cache TTL in milliseconds (default: 300000 = 5 minutes)
VITE_CACHE_TTL=300000

# Debug mode (enables verbose logging)
VITE_DEBUG=false
